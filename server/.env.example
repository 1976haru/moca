# Copy to .env and fill in. Each key is OPTIONAL — endpoints that need a missing
# key respond with a clear "not configured" error instead of crashing.

# Server
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,https://your-pages-site.example.com

# YouTube OAuth (Google Cloud Console → OAuth client ID, Web application)
# Required for /api/youtube/oauth/* and /api/youtube/captions/*
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://localhost:3001/api/youtube/oauth/callback

# YouTube Data API key (for /api/youtube/meta — optional; oEmbed used as fallback)
YOUTUBE_API_KEY=

# OpenAI Whisper for /api/remix/transcribe (optional — without this, endpoint
# returns a stub transcript with timestamps based on file duration)
OPENAI_API_KEY=

# Whisper language hint (auto if blank)
WHISPER_LANGUAGE=ko

# Storage for generated keyframe images (defaults to ./_tmp_frames served at /static/frames)
FRAMES_DIR=
PUBLIC_BASE_URL=http://localhost:3001
